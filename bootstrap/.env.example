# =============================================================================
# RentalApp — Bootstrap secrets template
#
# HOW TO USE:
#   cp bootstrap/.env.example bootstrap/.env
#   Fill in your values in bootstrap/.env  (never commit it)
#   pip install -r bootstrap/requirements.txt
#   python bootstrap/set-github-secrets.py
#
# NOTE: Azure values (AZURE_*) are auto-loaded from
#       ../AI-RentalApp-Ledger/bootstrap/.env if that file exists.
#       Only fill them in here if both repos are NOT in the same parent folder.
# =============================================================================

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_ORG=Ramprasath26
GITHUB_REPO=RentalApp-Build

# Personal Access Token — 'repo' scope (classic) or 'secrets:write' (fine-grained)
# Create at: https://github.com/settings/tokens/new
GITHUB_PAT=<your-github-pat>

# ── Docker Hub ────────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=<your-dockerhub-username>

# Docker Hub Access Token (not your password)
# Create at: https://hub.docker.com/settings/security
DOCKERHUB_TOKEN=<your-dockerhub-access-token>

# ── Azure Container Registry ──────────────────────────────────────────────────
# Get ACR name: az acr list --resource-group <rg> --query "[0].name" -o tsv
ACR_NAME=<your-acr-name>

# ACR login server is auto-derived as <ACR_NAME>.azurecr.io
# Set this only if it differs (e.g. private endpoint)
# ACR_LOGIN_SERVER=<acr-name>.azurecr.io

# ── SonarQube (optional) ──────────────────────────────────────────────────────
# Leave blank to skip — secrets with empty values are not set
SONAR_TOKEN=
SONAR_HOST_URL=

# ── Azure credentials ─────────────────────────────────────────────────────────
# Auto-loaded from ../AI-RentalApp-Ledger/bootstrap/.env if found.
# Only fill in if that file is not reachable from here.
#
# AZURE_APP_ID=
# AZURE_TENANT_ID=
# AZURE_SUBSCRIPTION_ID=
# AZURE_CLIENT_SECRET=
